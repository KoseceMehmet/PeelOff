# ============================================
# API KEYS FOR ENHANCED DISCOVERY
# ============================================
# Remove .example extension and fill in your keys
# All keys are OPTIONAL - tool works without them but with reduced functionality
# IMPORTANT: Use quotes around API keys to prevent parsing issues
# Example: SHODAN_API_KEY="your_actual_key_here"

# Shodan API Key (Internet-wide device search)
# Get from: https://account.shodan.io/
# Free tier: 1 request/second, Paid tier: 10+ requests/second
SHODAN_API_KEY="your_shodan_api_key_here"

# Censys API Credentials (Internet asset discovery)
# Get from: https://censys.io/account
# Free tier: 120 requests/minute, Paid tier: 1000+ requests/minute
CENSYS_API_ID="your_censys_api_id_here"
CENSYS_API_SECRET="your_censys_api_secret_here"

# SecurityTrails API Key (DNS and infrastructure intelligence)
# Get from: https://securitytrails.com/corp/api
# Free tier: 50 requests/minute, Paid tier: 1000+ requests/minute
SECURITYTRAILS_API_KEY="your_securitytrails_api_key_here"

# Fofa API Credentials (Chinese cyber threat intelligence)
# Get from: https://fofa.info/user/info
FOFA_EMAIL="your_fofa_email_here"
FOFA_KEY="your_fofa_key_here"

# ZoomEye API Key (Chinese cyberspace search engine)
# Get from: https://console.zoomeye.org/
# Free tier: 1000 requests/month, Paid tier: 10000+ requests/month
ZOOMEYE_API_KEY="your_zoomeye_api_key_here"

# BinaryEdge API Key (Internet scanning service)
# Get from: https://binaryedge.io/
# Free tier: 250 credits/month, Paid tier: 10000+ credits/month
BINARYEDGE_API_KEY="your_binaryedge_api_key_here"

# VirusTotal API Key (Historical DNS and subdomain discovery)
# Get from: https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/minute, Paid tier: 60+ requests/minute
VIRUSTOTAL_API_KEY="your_virustotal_api_key_here"

# GitHub API Token (Code repository scanning for origin IPs)
# Get from: https://github.com/settings/tokens
# Requires 'repo' scope. Free tier: 5000 requests/hour
GITHUB_TOKEN="your_github_token_here"

# ============================================
# SCAN CONFIGURATION
# ============================================

# Rate Limiting (requests per second)
# Lower values avoid detection, higher values increase speed
DEFAULT_RATE_LIMIT=1000
MAX_CONCURRENT_REQUESTS=10
API_TIMEOUT=30

# IPv6 Support (include IPv6 addresses in discovery)
# Set to true for IPv6-enabled targets
ENABLE_IPV6=false

# Private IP Scanning (include private network ranges)
# Set to true for internal network reconnaissance
ENABLE_PRIVATE_IP_SCAN=false

# Maximum Ports per Scan (limit port scanning scope)
# Common values: 100 (top ports), 1000 (common ports), 65535 (all ports)
MAX_PORTS_PER_SCAN=1000

# CDN Filtering (exclude known CDN IP ranges)
# Set to false if you want to scan CDN infrastructure
CDN_FILTER_ENABLED=true

# Fast Mode (aggressive scanning for high-speed internet connections)
# WARNING: May cause internet connection issues on slow connections
# Set to true only if you have very fast and stable internet
# Default: false (throttled mode for internet safety)
FAST_MODE=false

# ============================================
# ADVANCED OPTIONS
# ============================================

# User-Agent for HTTP requests
# Some services may block default user agents
HTTP_USER_AGENT="OriginIP-Discovery-Tool/4.0"

# Proxy Configuration (optional)
# Format: http://proxy.example.com:8080 or socks5://proxy.example.com:1080
# HTTP_PROXY=
# HTTPS_PROXY=

# Debug Mode (enable verbose logging for troubleshooting)
DEBUG_MODE=false
